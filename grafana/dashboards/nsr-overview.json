{
  "title": "NetWorker — Overview",
  "uid": "nsr-overview",
  "tags": ["networker", "nsr_exporter", "dell", "backup"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "timezone": "browser",
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "system",
        "label": "NetWorker System",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(nsr_up, system)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "System Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Systems Up",
      "type": "stat",
      "description": "1 = UP (green), 0 = DOWN (red) per NetWorker system.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" } } },
            { "type": "value", "options": { "1": { "text": "UP",   "color": "green" } } }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red",   "value": null },
              { "color": "green", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_up{system=~\"$system\"}",
          "legendFormat": "{{system}}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Critical Alerts",
      "type": "stat",
      "description": "Count of active Critical alerts by system.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (system) (nsr_alerts_active{system=~\"$system\", priority=\"Critical\"})",
          "legendFormat": "{{system}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Warning Alerts",
      "type": "stat",
      "description": "Count of active Warning alerts by system.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (system) (nsr_alerts_active{system=~\"$system\", priority=\"Warning\"})",
          "legendFormat": "{{system}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Active Sessions",
      "type": "stat",
      "description": "Total active sessions across all types.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum(nsr_active_sessions{system=~\"$system\"})"
        }
      ]
    },
    {
      "id": 6,
      "type": "row",
      "title": "Job Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 }
    },
    {
      "id": 7,
      "title": "Jobs by Completion Status",
      "type": "bargauge",
      "description": "Count of jobs grouped by completion_status across selected systems.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (completion_status) (nsr_job_status{system=~\"$system\"})",
          "legendFormat": "{{completion_status}}",
          "instant": true
        }
      ]
    },
    {
      "id": 8,
      "title": "Jobs by Type",
      "type": "bargauge",
      "description": "Count of jobs grouped by job_type.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "options": { "orientation": "horizontal", "displayMode": "basic" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (job_type) (nsr_job_status{system=~\"$system\"})",
          "legendFormat": "{{job_type}}",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "type": "row",
      "title": "Server Statistics",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 14 }
    },
    {
      "id": 10,
      "title": "Cumulative Backup Attempts",
      "type": "stat",
      "description": "nsr_server_saves_total — cumulative counter.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_server_saves_total{system=~\"$system\"}",
          "legendFormat": "{{system}}"
        }
      ]
    },
    {
      "id": 11,
      "title": "Cumulative Failed Backups",
      "type": "stat",
      "description": "nsr_server_bad_saves_total — cumulative counter.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_server_bad_saves_total{system=~\"$system\"}",
          "legendFormat": "{{system}}"
        }
      ]
    },
    {
      "id": 12,
      "title": "Cumulative Bytes Written",
      "type": "stat",
      "description": "nsr_server_save_size_bytes — cumulative counter.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_server_save_size_bytes{system=~\"$system\"}",
          "legendFormat": "{{system}}"
        }
      ]
    },
    {
      "id": 13,
      "title": "Cumulative Recover Attempts",
      "type": "stat",
      "description": "nsr_server_recovers_total — cumulative counter.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 15 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_server_recovers_total{system=~\"$system\"}",
          "legendFormat": "{{system}}"
        }
      ]
    },
    {
      "id": 20,
      "title": "Current Saves / Recovers",
      "type": "stat",
      "description": "Live concurrent saves and recovers vs server maximums.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_server_current_saves{system=~\"$system\"}",
          "legendFormat": "{{system}} current saves"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_server_current_recovers{system=~\"$system\"}",
          "legendFormat": "{{system}} current recovers"
        }
      ]
    },
    {
      "id": 21,
      "title": "Server Max Saves / Recovers",
      "type": "stat",
      "description": "Configured maximum concurrent saves and recovers.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 19 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "green" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_server_max_saves{system=~\"$system\"}",
          "legendFormat": "{{system}} max saves"
        },
        {
          "refId": "B",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_server_max_recovers{system=~\"$system\"}",
          "legendFormat": "{{system}} max recovers"
        }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "Infrastructure Snapshot",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 23 }
    },
    {
      "id": 16,
      "title": "Offline Devices",
      "type": "stat",
      "description": "Count of backup devices with status=offline. Any offline device turns the panel red.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(nsr_device_info{system=~\"$system\", status=\"offline\"}) or vector(0)",
          "legendFormat": "Offline devices"
        }
      ]
    },
    {
      "id": 17,
      "title": "Disabled Policies",
      "type": "stat",
      "description": "Count of protection policies with nsr_policy_enabled == 0. Yellow when any policy is disabled.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 24 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "count(nsr_policy_enabled{system=~\"$system\"} == 0) or vector(0)",
          "legendFormat": "Disabled policies"
        }
      ]
    }
  ]
}
