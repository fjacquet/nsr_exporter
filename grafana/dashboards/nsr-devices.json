{
  "title": "NetWorker — Devices & Media",
  "uid": "nsr-devices",
  "tags": ["networker", "nsr_exporter", "dell", "backup", "devices", "storage"],
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "5m",
  "timezone": "browser",
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "system",
        "label": "NetWorker System",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(nsr_up, system)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Device Inventory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Devices by Status",
      "type": "bargauge",
      "description": "Count of backup devices grouped by status (enabled/disabled/offline). Uses nsr_device_info label status.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (status) (nsr_device_info{system=~\"$system\"})",
          "legendFormat": "{{status}}",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Devices by Type",
      "type": "bargauge",
      "description": "Count of backup devices grouped by type (tape/disk/adv_file). Uses nsr_device_info label type.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "options": { "orientation": "horizontal", "displayMode": "basic" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (type) (nsr_device_info{system=~\"$system\"})",
          "legendFormat": "{{type}}",
          "instant": true
        }
      ]
    },
    {
      "id": 4,
      "title": "Total Device Capacity",
      "type": "stat",
      "description": "Sum of nsr_device_capacity_bytes across all devices. Use sum — this is a gauge, not a counter.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "value" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (system) (nsr_device_capacity_bytes{system=~\"$system\"})",
          "legendFormat": "{{system}}"
        }
      ]
    },
    {
      "id": 5,
      "title": "Offline Device Count",
      "type": "stat",
      "description": "Number of devices with status=offline. Alert threshold: any offline device is red.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 4, "w": 8, "x": 16, "y": 5 },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (system) (nsr_device_info{system=~\"$system\", status=\"offline\"})",
          "legendFormat": "{{system}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Device Inventory Table",
      "type": "table",
      "description": "All devices with name, type, status, and capacity.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "none" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #Info" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "Value #Capacity" },
            "properties": [ { "id": "unit", "value": "bytes" } ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          }
        ]
      },
      "targets": [
        {
          "refId": "Info",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_device_info{system=~\"$system\"}",
          "format": "table",
          "instant": true
        },
        {
          "refId": "Capacity",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_device_capacity_bytes{system=~\"$system\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "__name__": true, "job": true, "instance": true },
            "renameByName": {
              "device_name": "Device",
              "type": "Type",
              "status": "Status",
              "serial": "Serial",
              "system": "System",
              "Value #Capacity": "Capacity"
            }
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "row",
      "title": "Storage Node Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 }
    },
    {
      "id": 8,
      "title": "Storage Nodes by Status",
      "type": "bargauge",
      "description": "Count of storage nodes grouped by status. Uses nsr_storagenode_info label status.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (status) (nsr_storagenode_info{system=~\"$system\"})",
          "legendFormat": "{{status}}",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "title": "Devices per Storage Node",
      "type": "bargauge",
      "description": "nsr_storagenode_device_count per node — use sum, never rate (gauge).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 20 },
      "options": { "orientation": "horizontal", "displayMode": "basic" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_storagenode_device_count{system=~\"$system\"}",
          "legendFormat": "{{node}} ({{system}})",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Pool Capacity",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 }
    },
    {
      "id": 11,
      "title": "Pool Used %",
      "type": "gauge",
      "description": "nsr_pool_used_bytes / nsr_pool_capacity_bytes per pool. Thresholds: 70% yellow, 85% red.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 29 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green",  "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 85 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "100 * nsr_pool_used_bytes{system=~\"$system\"} / clamp_min(nsr_pool_capacity_bytes{system=~\"$system\"}, 1)",
          "legendFormat": "{{pool}} ({{system}})"
        }
      ]
    },
    {
      "id": 12,
      "title": "Pool Total Capacity",
      "type": "bargauge",
      "description": "nsr_pool_capacity_bytes per pool. Use sum — this is a gauge, not a counter.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 29 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": { "defaults": { "unit": "bytes" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_pool_capacity_bytes{system=~\"$system\"}",
          "legendFormat": "{{pool}} ({{system}})",
          "instant": true
        }
      ]
    },
    {
      "id": 13,
      "title": "Volumes per Pool",
      "type": "bargauge",
      "description": "nsr_pool_volume_count per pool.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 29 },
      "options": { "orientation": "horizontal", "displayMode": "basic" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "color": { "mode": "fixed", "fixedColor": "purple" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_pool_volume_count{system=~\"$system\"}",
          "legendFormat": "{{pool}} ({{system}})",
          "instant": true
        }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "Volume Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 }
    },
    {
      "id": 15,
      "title": "Volumes by Status",
      "type": "bargauge",
      "description": "Count of volumes by status (appendable/full/recyclable). Uses nsr_volume_status label status.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": {
        "defaults": {
          "unit": "none",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (status) (nsr_volume_status{system=~\"$system\"})",
          "legendFormat": "{{status}}",
          "instant": true
        }
      ]
    },
    {
      "id": 16,
      "title": "Volumes by Pool and Status",
      "type": "bargauge",
      "description": "Count of volumes grouped by pool and status.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "options": { "orientation": "horizontal", "displayMode": "basic" },
      "fieldConfig": { "defaults": { "unit": "none" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (pool, status) (nsr_volume_status{system=~\"$system\"})",
          "legendFormat": "{{pool}} / {{status}}",
          "instant": true
        }
      ]
    }
  ]
}
