{
  "title": "NetWorker — Devices & Media",
  "uid": "nsr-devices",
  "tags": ["networker", "nsr_exporter", "dell", "backup", "devices", "storage"],
  "schemaVersion": 39,
  "version": 2,
  "time": { "from": "now-6h", "to": "now" },
  "refresh": "1m",
  "timezone": "browser",
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {},
        "hide": 0
      },
      {
        "name": "system",
        "label": "NetWorker System",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${datasource}" },
        "query": "label_values(nsr_up, system)",
        "refresh": 2,
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "row",
      "title": "Device Inventory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 }
    },
    {
      "id": 2,
      "title": "Devices by Status",
      "type": "bargauge",
      "description": "Count of backup devices grouped by status. Uses nsr_device_info label status. Status values are raw strings from NetWorker (e.g. Enabled, Disabled, Service, offline).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 1 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "orange", "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (status) (nsr_device_info{system=~\"$system\"})",
          "legendFormat": "{{status}}",
          "instant": true
        }
      ]
    },
    {
      "id": 3,
      "title": "Devices by Media Type",
      "type": "bargauge",
      "description": "Count of backup devices grouped by media_type. Uses nsr_device_info label media_type.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 1 },
      "options": { "orientation": "horizontal", "displayMode": "basic" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (media_type) (nsr_device_info{system=~\"$system\"})",
          "legendFormat": "{{media_type}}",
          "instant": true
        }
      ]
    },
    {
      "id": 5,
      "title": "Offline Device Count",
      "type": "stat",
      "description": "Number of devices with status matching 'offline' (case-insensitive). Any offline device turns the panel red — investigate immediately.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 1 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "orientation": "auto", "textMode": "auto", "colorMode": "background" },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (system) (nsr_device_info{system=~\"$system\", status=~\"(?i)offline\"})",
          "legendFormat": "{{system}}"
        }
      ]
    },
    {
      "id": 6,
      "title": "Device Inventory Table",
      "type": "table",
      "description": "All devices with name, media_type, media_family, status, and serial.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 9 },
      "fieldConfig": {
        "defaults": { "unit": "none" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value #Info" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          }
        ]
      },
      "targets": [
        {
          "refId": "Info",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_device_info{system=~\"$system\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "__name__": true, "job": true, "instance": true },
            "renameByName": {
              "device_name": "Device",
              "media_type": "Media Type",
              "media_family": "Media Family",
              "status": "Status",
              "serial": "Serial",
              "system": "System"
            }
          }
        }
      ]
    },
    {
      "id": 7,
      "type": "row",
      "title": "Storage Node Health",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 }
    },
    {
      "id": 8,
      "title": "Storage Nodes by Enabled State",
      "type": "bargauge",
      "description": "Count of storage nodes grouped by enabled label. Uses nsr_storagenode_info label enabled (values: 'true'/'false').",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 20 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red",   "value": 1 }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (enabled) (nsr_storagenode_info{system=~\"$system\"})",
          "legendFormat": "{{enabled}}",
          "instant": true
        }
      ]
    },
    {
      "id": 9,
      "title": "Devices per Storage Node",
      "type": "bargauge",
      "description": "nsr_storagenode_device_count per node — use sum, never rate (gauge).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 16, "x": 8, "y": 20 },
      "options": { "orientation": "horizontal", "displayMode": "basic" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "color": { "mode": "fixed", "fixedColor": "blue" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_storagenode_device_count{system=~\"$system\"}",
          "legendFormat": "{{node}} ({{system}})",
          "instant": true
        }
      ]
    },
    {
      "id": 10,
      "type": "row",
      "title": "Pool Inventory",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 28 }
    },
    {
      "id": 11,
      "title": "Pools by Type",
      "type": "bargauge",
      "description": "nsr_pool_info — count of pools by pool_type (info gauge =1, replaces removed capacity metrics).",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 29 },
      "options": { "orientation": "horizontal", "displayMode": "basic" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by (pool_type) (nsr_pool_info{system=~\"$system\"})",
          "legendFormat": "{{pool_type}}",
          "instant": true
        }
      ]
    },
    {
      "id": 12,
      "title": "Pool Inventory Table",
      "type": "table",
      "description": "nsr_pool_info — all pools with type and enabled state.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 29 },
      "fieldConfig": {
        "defaults": { "unit": "none" },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "Value" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          },
          {
            "matcher": { "id": "byName", "options": "Time" },
            "properties": [ { "id": "custom.hidden", "value": true } ]
          }
        ]
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "nsr_pool_info{system=~\"$system\"}",
          "format": "table",
          "instant": true
        }
      ],
      "transformations": [
        { "id": "merge", "options": {} },
        {
          "id": "organize",
          "options": {
            "excludeByName": { "__name__": true, "job": true, "instance": true },
            "renameByName": {
              "pool": "Pool",
              "pool_type": "Type",
              "enabled": "Enabled",
              "system": "System"
            }
          }
        }
      ]
    },
    {
      "id": 14,
      "type": "row",
      "title": "Volume Status",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 37 }
    },
    {
      "id": 15,
      "title": "Volumes by Status",
      "type": "bargauge",
      "description": "Count of volumes by primary status. NetWorker's nsr_volume_status label is a comma-joined array (e.g. 'Recyclable,WORM'). label_replace extracts the first token before any comma as 'primary_status' to produce meaningful, non-fragmented buckets.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 38 },
      "options": { "orientation": "horizontal", "displayMode": "gradient" },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null }
            ]
          },
          "color": { "mode": "thresholds" }
        },
        "overrides": []
      },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by(primary_status) (label_replace(nsr_volume_status{system=~\"$system\"}, \"primary_status\", \"$1\", \"status\", \"([^,]+).*\"))",
          "legendFormat": "{{primary_status}}",
          "instant": true
        }
      ]
    },
    {
      "id": 16,
      "title": "Volumes by Pool and Status",
      "type": "bargauge",
      "description": "Count of volumes grouped by pool and primary status. NetWorker's nsr_volume_status label is a comma-joined array (e.g. 'Recyclable,WORM'). label_replace extracts the first token before any comma as 'primary_status' to avoid fragmented buckets per compound status string.",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 38 },
      "options": { "orientation": "horizontal", "displayMode": "basic" },
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "${datasource}" },
          "expr": "sum by(pool, primary_status) (label_replace(nsr_volume_status{system=~\"$system\"}, \"primary_status\", \"$1\", \"status\", \"([^,]+).*\"))",
          "legendFormat": "{{pool}} / {{primary_status}}",
          "instant": true
        }
      ]
    }
  ]
}
