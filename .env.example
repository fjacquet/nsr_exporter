# Copy to .env for a single-target quickstart. ".env is nice, config.yaml is the
# way" — these only fill the ${ENV_VAR} references in config.yaml and never
# override variables already set in the real environment.

# Exporter image tag (GHCR). Pin a release for production instead of :latest.
NSR_TAG=latest

# NetWorker system credentials. config.yaml references these as ${NSR1_USERNAME} /
# ${NSR1_PASSWORD}. Use read-only monitoring credentials where possible.
NSR1_USERNAME=admin
NSR1_PASSWORD=changeme

# Optional: enable OTLP push export by pointing at a collector.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317

# Grafana admin login (used by docker-compose.yml / docker-compose.ghcr.yml).
# Matches the advertised local-demo login (admin/admin); change for any real deploy.
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin

# Public URL Grafana is served at. For the local demo this is localhost; set it to
# your real host:port when serving Grafana remotely so login redirects resolve.
GF_SERVER_ROOT_URL=http://localhost:3000
